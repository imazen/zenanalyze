                 (HEAD of feat/dispatch-plan at measurement time; the
                 perf example + content-aware-gate calibration are
                 committed in the following commit on this branch)
hostname:        lilith
cpu:             AMD Ryzen 9 7950X (no thermal throttling)
toolchain:       cargo (release profile, NO target-cpu=native — runtime
                 SIMD dispatch is what ships)
features:        experimental,hdr
