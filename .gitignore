# Trained picker model JSONs — reproducible from the features TSV +
# train_hybrid.py invocation, often exceed jj's 1 MiB snapshot limit.
# Keep correlation_*.json and student_perm_*.json (small, comparison-
# critical), drop hybrid model weights.
benchmarks/*_hybrid_*.json
benchmarks/**/distill_*_picker.json
benchmarks/**/multi_codec_*_picker.json

# Large per-codec bake JSON outputs from joint pretrain (reproducible via train_multi_codec.py)
benchmarks/joint_pretrain*_2026-*/joint*_picker.json
benchmarks/joint_pretrain*_2026-*/jointpre*_picker.json
benchmarks/joint_pretrain_bigtrunk*_2026-*/*_picker.json
benchmarks/joint_finetune*_2026-*/finetune*_picker.json
